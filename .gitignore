### Claude ###
.claude/worktrees
.claude/settings.local.json
CLAUDE.local.md

### Publishing secrets ###
# Credentials for Sonatype Central Portal + GPG signing live in user-home
# (~/.gradle/gradle.properties). The committed root /gradle.properties only
# holds public per-module version numbers — never put credentials there.
secring.gpg
*.asc

### Graphify ###
# keep graph outputs, skip heavy/local-only files
# optional: commit for shared extraction speed, skip to keep repo small
graphify-out/cache/
# mtime-based, invalid after git clone — always gitignore this
graphify-out/manifest.json
# local token tracking, not useful to share
graphify-out/cost.json
# local working files
.graphify_incremental.json
.graphify_old.json
.graphify_uncached.txt
.graphify_python


# gradle gitignore
.gradle
/build/
# subproject build dirs (nbt/build, nbt-mca/build, …)
**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Cache of project
.gradletasknamecache

# # Work around https://youtrack.jetbrains.com/issue/IDEA-116898
# gradle/wrapper/gradle-wrapper.properties


# eclipse buildship gitignore
.project
.classpath
.gradle
.settings


# eclipse gitignore
.metadata
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# Eclipse Core
.project

# External tool builders
.externalToolBuilders/

# Locally stored "Eclipse launch configurations"
*.launch

# PyDev specific (Python IDE for Eclipse)
*.pydevproject

# CDT-specific (C/C++ Development Tooling)
.cproject

# JDT-specific (Eclipse Java Development Tools)
.classpath

# Java annotation processor (APT)
.factorypath

# PDT-specific (PHP Development Tools)
.buildpath

# sbteclipse plugin
.target

# Tern plugin
.tern-project

# TeXlipse plugin
.texlipse

# STS (Spring Tool Suite)
.springBeans

# Code Recommenders
.recommenders/

# IDEA folder
.idea/

# .iml files
*.iml

# ignore javadoc for now
doc/

# ignore out
out/

*.patch
TESTDBG/
ScratchpadTest.java
